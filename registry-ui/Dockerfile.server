# On-prem server mode. Build from repo root: docker build -f registry-ui/Dockerfile.server .
FROM node:18-alpine
WORKDIR /provena

# Copy full repo for shared react-libs
COPY . .

WORKDIR /provena/registry-ui
# Create react-libs symlink (replaces dev_lib_setup.sh preinstall)
RUN mkdir -p src && ln -sf ../../utilities/packages/typescript/react-libs/src src/react-libs
RUN npm install --ignore-scripts && npm run build:example

EXPOSE 3000
CMD ["npm", "run", "serve"]

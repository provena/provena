# On-prem server mode. Build from repo root: docker build -f data-store-api/Dockerfile.server .
FROM python:3.10
WORKDIR /provena
COPY . .
WORKDIR /provena/data-store-api
RUN pip install --no-cache-dir -r requirements.txt
EXPOSE 8000
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]

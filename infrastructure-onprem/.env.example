# Copy to .env and adjust for your environment

# UI build (baked in at build time; rebuild UIs after changing)
VITE_APP_BASE_URL=http://localhost
VITE_KEYCLOAK_REALM=provena
# Contact us button URL (use # for no link, or e.g. mailto:support@example.com or https://...)
VITE_CONTACT_US_LINK=#
# Theme ID (e.g. default); docs link for Documentation / Help
VITE_THEME_ID=default
VITE_DOCUMENTATION_BASE_LINK=https://docs.provena.io

# Auth API CORS: set to your host when accessing UIs by hostname (e.g. rrap1.it.csiro.au)
DOMAIN_BASE=localhost

# HTTPS (Caddy): when using --profile https, set to your hostname (e.g. rrap1.it.csiro.au).
# Caddy reverse-proxies UIs, APIs, and Keycloak. Keycloak is on port 8443 (HTTPS).
CADDY_DOMAIN=localhost
# When using Caddy/HTTPS, set to 8443 so UIs use Keycloak behind Caddy. Otherwise 8180.
VITE_KEYCLOAK_PORT=8180

# Auth API service token (on-prem): Keycloak client credentials for job launch etc.
# Create a Keycloak client (e.g. auth-api-service) with Client authentication ON and
# a client secret; assign needed roles. Then set:
# KEYCLOAK_SERVICE_CLIENT_ID=auth-api-service
# KEYCLOAK_SERVICE_CLIENT_SECRET=<secret from Keycloak>

# Registry API (PostgreSQL mode)
DB_BACKEND=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/registry_db
REGISTRY_TABLE_NAME=registry_items
AUTH_TABLE_NAME=auth_items
LOCK_TABLE_NAME=lock_items

# Handle / Identifier service
HANDLE_API_ENDPOINT=http://localhost:8005

# Data Store (MinIO)
STORAGE_BACKEND=minio
S3_ENDPOINT_URL=http://localhost:9000
S3_USE_SSL=false
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_STORAGE_BUCKET_NAME=provena

# Search (OpenSearch)
SEARCH_AUTH_TYPE=basic
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_PORT=9200
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false
SEARCH_DOMAIN=localhost
